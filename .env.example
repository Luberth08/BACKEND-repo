# ─── JWT ─────────────────────────────────────────────────────
PROJECT_NAME="Plataforma Asistencia Vehicular"
SECRET_KEY=your_secret_key_here_min_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ─── Base de datos ────────────────────────────────────────────
# Desarrollo local:
DATABASE_URL=postgresql+asyncpg://usuario:password@localhost:5432/asistencia_vehicular
SYNC_DATABASE_URL=postgresql://usuario:password@localhost:5432/asistencia_vehicular
BASE_URL=http://localhost:8000

# Producción (descomentar y completar):
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DB?ssl=require
# SYNC_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require
# BASE_URL=https://tu-dominio.onrender.com

# ─── SMTP / Gmail ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
SMTP_FROM=tu_correo@gmail.com

# ─── IA (Groq API) ───────────────────────────────────────────
# Obtén tu key en: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# Modelo LLM (opciones: llama-3.1-8b-instant, llama-3.1-70b-versatile, mixtral-8x7b-32768)
GROQ_MODEL=llama-3.1-8b-instant

# ─── Whisper (transcripción local) ───────────────────────────
# Opciones: tiny, base, small, medium, large-v3
WHISPER_MODEL_SIZE=base

# ─── Flags ───────────────────────────────────────────────────
USE_REAL_AI=true
